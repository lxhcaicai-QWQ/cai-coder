# Feishu App Configuration
# Get these from Feishu Developer Console
FEISHU_APP_ID=cli_xxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=  # Optional, leave empty if not using encryption
FEISHU_VERIFICATION_TOKEN=xxxxxxxx

# Cai-Coder API Configuration
CAICODER_API_URL=http://localhost:8000
CAICODER_MODEL=cai-coder
CAICODER_STREAM=False

# Bot Configuration
BOT_NAME=cai-coder
BOT_PORT=8080
BOT_HOST=0.0.0.0

# Conversation Settings
MAX_HISTORY=10
SESSION_TTL=3600

# Connection Mode
CONNECTION_MODE=webhook  # "webhook" or "subscription" (SSE long connection)
